#!/bin/sh

TAG='r3mini-hotspot'
CONFIG='r3mini_hotspot.main'

cfg() { uci -q get "$CONFIG.$1"; }

is_uint() { case "$1" in ''|*[!0-9]*) return 1;; *) return 0;; esac; }

enabled() { [ "$(cfg enabled)" = 1 ]; }

scan_channel() {
	local target="$1" raw rc lock='/var/lock/r3mini-hotspot-scan'
	mkdir "$lock" 2>/dev/null || return 1
	rc=0
	/sbin/wifi down radio1 >/dev/null 2>&1 || rc=1
	iw dev r3scan0 del 2>/dev/null || true
	if [ "$rc" -eq 0 ] && iw phy phy1 interface add r3scan0 type station 2>/dev/null; then
		ip link set r3scan0 up 2>/dev/null || rc=1
	else
		rc=1
	fi
	if [ "$rc" -eq 0 ]; then
		raw="$(iw dev r3scan0 scan ssid "$target" 2>/dev/null)" || rc=1
	fi
	iw dev r3scan0 del 2>/dev/null || true
	/sbin/wifi up radio1 >/dev/null 2>&1 || rc=1
	rmdir "$lock" 2>/dev/null || true
	[ "$rc" -eq 0 ] || return 1
	printf '%s\n' "$raw" | awk -v target="$target" '
		/^BSS / { freq = 0; signal = -999 }
		/^[[:space:]]*freq:/ { freq = $2 + 0 }
		/^[[:space:]]*signal:/ { signal = $2 + 0 }
		/^[[:space:]]*SSID:/ {
			ssid = $0; sub(/^[[:space:]]*SSID:[[:space:]]*/, "", ssid)
			if (ssid == target && (freq == 5180 || freq == 5200 || freq == 5220 || freq == 5240 || freq == 5745 || freq == 5765 || freq == 5785 || freq == 5805) && (!found || signal > best_signal)) {
				best_freq = freq; best_signal = signal; found = 1
			}
		}
		END { if (!found) exit 1; print (best_freq - 5000) / 5 }'
}

wwan_up() {
	[ "$(ifstatus wwan 2>/dev/null | jsonfilter -e '@.up' 2>/dev/null)" = true ] &&
		[ -n "$(ifstatus wwan 2>/dev/null | jsonfilter -e '@["ipv4-address"][0].address' 2>/dev/null)" ] &&
		iw dev phy1-sta0 link 2>/dev/null | grep -q '^Connected to '
}

interval="$(cfg check_interval)"; is_uint "$interval" && [ "$interval" -ge 5 ] && [ "$interval" -le 3600 ] || interval=20
limit="$(cfg failure_limit)"; is_uint "$limit" && [ "$limit" -ge 1 ] && [ "$limit" -le 20 ] || limit=3
cooldown="$(cfg cooldown)"; is_uint "$cooldown" && [ "$cooldown" -ge 30 ] && [ "$cooldown" -le 3600 ] || cooldown=180
radio="$(cfg radio)"; [ -n "$radio" ] || radio=radio1

failures=0
reconnect_rounds=0
last_reconf=0
scan_backoff="$cooldown"
while :; do
	if ! enabled; then
		failures=0
		sleep "$interval"
		continue
	fi

	if wwan_up; then
		failures=0
		reconnect_rounds=0
		scan_backoff="$cooldown"
	else
		failures=$((failures + 1))
		if [ "$failures" -ge "$limit" ]; then
			logger -t "$TAG" "wwan unavailable; requesting reconnect"
			ifup wwan >/dev/null 2>&1 || true
			failures=0
			reconnect_rounds=$((reconnect_rounds + 1))
			now="$(date +%s)"
			if [ "$reconnect_rounds" -ge 3 ] && [ $((now - last_reconf)) -ge "$scan_backoff" ]; then
				ssid="$(uci -q get wireless.r3mini_phone_sta.ssid)"
				channel="$(scan_channel "$ssid" || true)"
				if [ -n "$channel" ] && [ "$channel" != "$(uci -q get wireless.$radio.channel)" ]; then
					logger -t "$TAG" "hotspot moved to channel $channel; aligning $radio"
					if ! uci set "wireless.$radio.channel=$channel" || ! uci commit wireless; then
						uci -q revert wireless || true
						logger -t "$TAG" "channel update failed; keeping current radio configuration"
						last_reconf="$now"
						reconnect_rounds=0
						continue
					fi
					if uci set "$CONFIG.target_channel=$channel"; then
						uci commit r3mini_hotspot || logger -t "$TAG" "target channel state commit failed"
					fi
					/sbin/wifi reconf "$radio" >/dev/null 2>&1 || logger -t "$TAG" "wireless reconfiguration failed"
				else
					logger -t "$TAG" "wwan reconnect pending; hotspot channel unchanged or not visible"
				fi
				last_reconf="$now"
				scan_backoff=$((scan_backoff * 2))
				[ "$scan_backoff" -le 1800 ] || scan_backoff=1800
				reconnect_rounds=0
			fi
		fi
	fi
	sleep "$interval"
done
