config fan 'main'
	option sensor '/sys/class/thermal/thermal_zone0/temp'
	option mode '/sys/class/thermal/thermal_zone0/mode'
	option pwm '/sys/class/hwmon/hwmon1/pwm1'
	option pwm_enable '/sys/class/hwmon/hwmon1/pwm1_enable'
	option stop_temp '30000'
	option start_temp '35000'
	option medium_down '35000'
	option medium_up '38000'
	option high_down '37000'
	option high_up '40000'
	option interval '5'
